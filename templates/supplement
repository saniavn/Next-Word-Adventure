        .slideshow-container {
            max-width: 100%;
            position: relative;
            margin: auto;
            overflow: hidden; /* Add this to prevent content from spilling out */
        }

        .mySlides {
            display: none;
            animation: fadeEffect 1.5s;
            position: relative; /* Ensure relative positioning for consistent animation */
        }

        .prev, .next {
            cursor: pointer;
            position: absolute;
            top: 50%;
            transform: translateY(-50%); /* Center the buttons vertically */
