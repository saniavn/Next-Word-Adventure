            padding: 16px;
            color: white;
            font-weight: bold;
            font-size: 18px;
            transition: 0.6s ease;
            border-radius: 0 3px 3px 0;
            user-select: none;
            z-index: 10; /* Make sure arrows are above the images */
        }

        .prev {
            left: 0px;
            border-radius: 3px 0 0 3px;
        }

        .next {
